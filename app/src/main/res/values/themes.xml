<resources>
    <!-- - - - - - - - - - - - - - - - - - - - - - 기본 테마 - - - - - - - - - - - - - - - - - - - - - - -->
    <style name="Base.Theme.Fromis_9" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:colorBackground">@color/white</item>

        <item name="android:fontFamily">@font/nanum_square_round_bold</item>
    </style>

    <style name="Theme.Fromis_9" parent="Base.Theme.Fromis_9" />

    <!-- - - - - - - - - - - - - - - - - - - - - - 커스텀 스타일 - - - - - - - - - - - - - - - - - - - - - - -->
    <!-- SmoothBottomBar -->
    <style name="StyleSmoothBottomBar">
        <item name="backgroundColor">@android:color/transparent</item>
        <item name="iconSize">26dp</item>
        <item name="iconTint">@color/dark_gray</item>
        <item name="iconTintActive">@color/colorPrimary</item>
        <item name="itemFontFamily">@font/nanum_square_round_bold</item>
        <item name="textColor">@color/colorPrimary</item>
        <item name="textSize">18dp</item>
    </style>

    <!-- CardView -->
    <style name="StyleCardView" parent="Widget.MaterialComponents.CardView">
        <item name="android:backgroundTint">@color/white</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ToggleButton -->
    <style name="StyleToggleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:fontFamily">@font/nanum_square_round_extra_bold</item>
        <item name="android:textColor">@color/color_togglebutton_text</item>
        <item name="android:textSize">14dp</item>
        <item name="strokeColor">@color/color_togglebutton_border</item>
    </style>
</resources>